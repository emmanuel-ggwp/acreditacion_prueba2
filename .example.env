
DATABASE_URL="postgres://postgres:password@localhost:5432/acreditacion"
JWT_SECRET="your-super-secret-jwt-key"
JWT_REFRESH_SECRET="your-super-secret-jwt-refresh-key"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
NODE_ENV="development"

# EmailJS (claves públicas; se usan en el cliente de la landing)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""

# Correo de contacto mostrado en la landing cuando un participante ya está inscrito
NEXT_PUBLIC_MODIFY_CONTACT_EMAIL=""
